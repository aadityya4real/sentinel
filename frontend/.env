# Backend API base URL. Leave empty to use the Vite dev-server proxy (/api -> http://localhost:8080).
VITE_API_URL=

# When "true", the frontend substitutes realistic mock data if the backend is
# unreachable or returns no hosts/events. Dev-only safety net — never active in production builds.
VITE_USE_MOCK_DATA=true

# Server-state refresh interval in milliseconds (dashboard, host table, health).
VITE_REFRESH_INTERVAL_MS=15000
